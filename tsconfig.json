{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "es6",
      "dom"
    ],
    "module": "es6",
    "moduleResolution": "bundler",
    "jsx": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "client/app/*"
      ],
      "@bundles/*": [
        "client/app/bundles/*"
      ],
      "@components/*": [
        "client/app/components/*"
      ],
      "@packs/*": [
        "client/app/packs/*"
      ],
      "@styles/*": [
        "client/app/assets/styles/*"
      ]
    },
    "declaration": false,
    "sourceMap": true,
    "noEmit": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "ignoreDeprecations": "5.0"
  },
  "exclude": [
    "**/*.spec.ts",
    "node_modules",
    "vendor",
    "public"
  ],
  "mdx": {
    "checkMdx": true
  },
  "compileOnSave": false
}